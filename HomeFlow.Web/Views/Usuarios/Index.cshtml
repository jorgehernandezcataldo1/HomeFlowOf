@* HomeFlow.Web/Views/Usuarios/Index.cshtml *@
@{
    ViewData["Title"] = "Usuarios";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Usuarios</h3>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrearUsuario">
        <i class="bi bi-plus-lg"></i> Nuevo usuario
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Rut</th><th>Nombre</th><th>Correo</th><th>Estado</th><th></th></tr>
                </thead>
                <tbody id="tablaUsuarios">
                    <tr><td colspan="5" class="text-center text-muted py-4">Cargando...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCrearUsuario" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="formCrearUsuario">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" id="btnCerrarModalUsuario"></button>
                </div>
                <div class="modal-body">
                    <div id="usuarioError" class="alert alert-danger d-none"></div>
                    <div class="mb-2">
                        <label class="form-label">Rut</label>
                        <input class="form-control" id="u_rut" placeholder="12345678-9" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Nombres</label>
                            <input class="form-control" id="u_nombres" required>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Apellidos</label>
                            <input class="form-control" id="u_apellidos" required>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Correo</label>
                        <input type="email" class="form-control" id="u_correo" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Contraseña</label>
                            <input type="password" class="form-control" id="u_password" required minlength="8">
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Confirmar</label>
                            <input type="password" class="form-control" id="u_confirmar" required minlength="8">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function cargarUsuarios() {
            const tbody = document.getElementById('tablaUsuarios');
            const res = await (await apiFetch('/api/usuarios')).json();
            if (!res.success) { tbody.innerHTML = `<tr><td colspan="5" class="text-danger text-center py-3">${res.message}</td></tr>`; return; }
            if (res.data.length === 0) { tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-3">Sin usuarios registrados.</td></tr>`; return; }

            tbody.innerHTML = res.data.map(u => `
                <tr>
                    <td>${u.rut}</td>
                    <td>${u.nombreCompleto}</td>
                    <td>${u.correo}</td>
                    <td>
                        ${u.activo ? '<span class="badge bg-success">Activo</span>' : '<span class="badge bg-secondary">Inactivo</span>'}
                        ${u.bloqueado ? '<span class="badge bg-danger ms-1">Bloqueado</span>' : ''}
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-warning" onclick="cambiarBloqueo(${u.idUsuario}, ${!u.bloqueado})">
                            ${u.bloqueado ? 'Desbloquear' : 'Bloquear'}
                        </button>
                    </td>
                </tr>`).join('');
        }

        async function cambiarBloqueo(id, bloquear) {
            await apiFetch(`/api/usuarios/${id}/bloqueo?bloquear=${bloquear}`, { method: 'PATCH' });
            cargarUsuarios();
        }

        document.getElementById('formCrearUsuario').addEventListener('submit', async (e) => {
            e.preventDefault();
            const errorBox = document.getElementById('usuarioError');
            errorBox.classList.add('d-none');

            const payload = {
                rut: document.getElementById('u_rut').value,
                nombres: document.getElementById('u_nombres').value,
                apellidos: document.getElementById('u_apellidos').value,
                correo: document.getElementById('u_correo').value,
                password: document.getElementById('u_password').value,
                confirmarPassword: document.getElementById('u_confirmar').value
            };

            const resp = await apiFetch('/api/usuarios', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const res = await resp.json();

            if (!resp.ok || !res.success) {
                errorBox.textContent = res.message || (res.errors ? Object.values(res.errors).join(' ') : 'Error al crear el usuario.');
                errorBox.classList.remove('d-none');
                return;
            }

            document.getElementById('formCrearUsuario').reset();
            document.getElementById('btnCerrarModalUsuario').click();
            cargarUsuarios();
        });

        cargarUsuarios();
    </script>
}