@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_LoginLayout";
}

<div class="auth-shell">
    <div class="container-fluid h-100">
        <div class="row g-0 h-100 justify-content-center align-items-stretch">

            <!-- Panel de marca (oculto en móvil) -->
            <div class="col-lg-5 d-none d-lg-flex auth-brand-panel">
                <div class="auth-brand-content">
                    <div class="auth-brand-logo mb-4">
                        <i class="bi bi-key-fill"></i>
                    </div>
                    <h1 class="auth-brand-title">HomeFlow</h1>
                    <p class="auth-brand-subtitle">
                        La gestión de arriendos y ventas, ordenada de punta a punta:
                        propietarios, propiedades, visitas, checklists y contratos
                        en un solo lugar.
                    </p>
                    <ul class="auth-brand-list">
                        <li><i class="bi bi-check2"></i>Match automático entre clientes y propiedades</li>
                        <li><i class="bi bi-check2"></i>Documentos que se generan con un clic</li>
                        <li><i class="bi bi-check2"></i>Todo tu proceso, sin planillas sueltas</li>
                    </ul>
                </div>
            </div>

            <!-- Panel de formulario -->
            <div class="col-12 col-lg-7 d-flex align-items-center justify-content-center py-5">
                <div class="auth-form-card">
                    <div class="d-lg-none text-center mb-4">
                        <i class="bi bi-key-fill auth-brand-logo-sm"></i>
                        <h1 class="h4 fw-bold mt-2 mb-0">HomeFlow</h1>
                    </div>

                    <h2 class="h3 fw-bold mb-1">Bienvenido de vuelta</h2>
                    <p class="text-muted mb-4">Ingresa tus credenciales para acceder a tu panel.</p>

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3" role="alert"></div>
                    }

                    <form asp-controller="Auth" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Correo" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                                <input asp-for="Correo" class="form-control" placeholder="nombre@correo.cl"
                                       autocomplete="username" autofocus />
                            </div>
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-lock"></i></span>
                                <input asp-for="Password" id="passwordInput" class="form-control" placeholder="••••••••"
                                       autocomplete="current-password" />
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword"
                                        aria-label="Mostrar contraseña" tabindex="-1">
                                    <i class="bi bi-eye" id="togglePasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input asp-for="RecordarMe" class="form-check-input" />
                                <label asp-for="RecordarMe" class="form-check-label small text-muted"></label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-brand w-100 py-2 fw-semibold">
                            Iniciar sesión
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('togglePassword');
            var input = document.getElementById('passwordInput');
            var icon = document.getElementById('togglePasswordIcon');
            if (!toggle || !input || !icon) return;

            toggle.addEventListener('click', function () {
                var isPassword = input.getAttribute('type') === 'password';
                input.setAttribute('type', isPassword ? 'text' : 'password');
                icon.classList.toggle('bi-eye');
                icon.classList.toggle('bi-eye-slash');
            });
        })();
    </script>
}
