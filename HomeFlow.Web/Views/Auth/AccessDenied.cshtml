@{
    ViewData["Title"] = "Acceso denegado";
    Layout = "_LoginLayout";
}

<div class="auth-shell d-flex align-items-center justify-content-center">
    <div class="text-center px-4" style="max-width: 420px;">
        <i class="bi bi-shield-lock display-1 text-brand mb-3 d-block"></i>
        <h1 class="h3 fw-bold mb-2">No tienes acceso a esta sección</h1>
        <p class="text-muted mb-4">
            Tu usuario no cuenta con los permisos necesarios. Si crees que esto
            es un error, contacta al administrador de tu empresa en HomeFlow.
        </p>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-brand px-4">Volver al inicio</a>
    </div>
</div>
