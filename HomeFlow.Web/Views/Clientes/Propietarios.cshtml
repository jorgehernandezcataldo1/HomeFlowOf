@* HomeFlow.Web/Views/Clientes/Propietarios.cshtml *@
@{
    ViewData["Title"] = "Propietarios";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Propietarios</h3>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCrearPropietario">
        <i class="bi bi-plus-lg"></i> Nuevo propietario
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr><th>Rut</th><th>Nombre</th><th>Correo</th><th>Teléfono</th><th></th></tr>
                </thead>
                <tbody id="tablaPropietarios">
                    <tr><td colspan="5" class="text-center text-muted py-4">Cargando...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalCrearPropietario" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="formCrearPropietario">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo propietario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" id="btnCerrarModalPropietario"></button>
                </div>
                <div class="modal-body">
                    <div id="propietarioError" class="alert alert-danger d-none"></div>
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Rut</label>
                            <input class="form-control" id="p_rut" placeholder="12345678-9" required>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Nombres</label>
                            <input class="form-control" id="p_nombres" required>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Apellidos</label>
                            <input class="form-control" id="p_apellidos" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Correo</label>
                            <input type="email" class="form-control" id="p_correo" required>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Teléfono</label>
                            <input class="form-control" id="p_telefono" placeholder="912345678">
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Dirección</label>
                        <input class="form-control" id="p_direccion">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Estado civil</label>
                            <select class="form-select" id="p_estadoCivil">
                                <option value="1">Soltero</option>
                                <option value="2">Casado</option>
                                <option value="3">Divorciado</option>
                                <option value="4">Viudo</option>
                                <option value="5">Conviviente civil</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Teléfono de emergencia</label>
                            <input class="form-control" id="p_telefonoEmergencia">
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Notas</label>
                        <textarea class="form-control" id="p_notas" rows="2"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="p_esArrendatario">
                        <label class="form-check-label" for="p_esArrendatario">
                            También busca arrendar/comprar otra propiedad
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalChecklist" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Checklist del propietario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" id="btnCerrarModalChecklist"></button>
            </div>
            <div class="modal-body" id="checklistBody">
                <div class="text-center text-muted py-4">Cargando checklist...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarChecklist">Guardar evaluación</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function cargarPropietarios() {
            const tbody = document.getElementById('tablaPropietarios');
            const res = await (await apiFetch('/api/clientes?soloPropietarios=true')).json();
            if (!res.success) { tbody.innerHTML = `<tr><td colspan="5" class="text-danger text-center py-3">${res.message}</td></tr>`; return; }
            if (res.data.length === 0) { tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-3">Sin propietarios registrados.</td></tr>`; return; }

            tbody.innerHTML = res.data.map(c => `
                <tr>
                    <td>${c.rut}</td>
                    <td>${c.nombreCompleto}</td>
                    <td>${c.correo}</td>
                    <td>${c.telefono ?? ''}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modalChecklist" data-cliente-id="${c.idCliente}">
                            <i class="bi bi-check2-square"></i> Checklist
                        </button>
                    </td>
                </tr>`).join('');
        }

        document.getElementById('formCrearPropietario').addEventListener('submit', async (e) => {
            e.preventDefault();
            const errorBox = document.getElementById('propietarioError');
            errorBox.classList.add('d-none');

            const payload = {
                rut: document.getElementById('p_rut').value,
                nombres: document.getElementById('p_nombres').value,
                apellidos: document.getElementById('p_apellidos').value,
                correo: document.getElementById('p_correo').value,
                telefono: document.getElementById('p_telefono').value,
                direccion: document.getElementById('p_direccion').value,
                estadoCivil: parseInt(document.getElementById('p_estadoCivil').value),
                telefonoEmergencia: document.getElementById('p_telefonoEmergencia').value,
                notas: document.getElementById('p_notas').value,
                esArrendatarioComprador: document.getElementById('p_esArrendatario').checked
            };

            const resp = await apiFetch('/api/clientes/propietarios', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const res = await resp.json();

            if (!resp.ok || !res.success) {
                errorBox.textContent = res.message || (res.errors ? Object.values(res.errors).join(' ') : 'Error al crear el propietario.');
                errorBox.classList.remove('d-none');
                return;
            }

            document.getElementById('formCrearPropietario').reset();
            document.getElementById('btnCerrarModalPropietario').click();
            cargarPropietarios();
        });

        let checklistClienteId = null;
        let checklistPlantillaId = null;

        document.getElementById('modalChecklist').addEventListener('show.bs.modal', async (event) => {
            checklistClienteId = event.relatedTarget.getAttribute('data-cliente-id');
            const body = document.getElementById('checklistBody');
            body.innerHTML = '<div class="text-center text-muted py-4">Cargando checklist...</div>';

            const res = await (await apiFetch('/api/checklist/plantilla/Cliente')).json();

            if (!res.success) {
                body.innerHTML = `<div class="alert alert-warning mb-0">${res.message} Configúralo en <a href="/Checklist/Configuracion">Checklists</a>.</div>`;
                checklistPlantillaId = null;
                return;
            }

            checklistPlantillaId = res.data.idChecklistPlantilla;
            body.innerHTML = res.data.items.map(item => `
                <div class="border-bottom pb-2 mb-2">
                    <div class="form-check">
                        <input class="form-check-input checklist-item" type="checkbox" id="item_${item.idChecklistItem}" data-item-id="${item.idChecklistItem}">
                        <label class="form-check-label" for="item_${item.idChecklistItem}">
                            ${item.descripcion} ${item.obligatorio ? '<span class="text-danger">*</span>' : ''}
                        </label>
                    </div>
                    <input type="text" class="form-control form-control-sm mt-1 checklist-comentario" data-item-id="${item.idChecklistItem}" placeholder="Comentario (opcional)">
                </div>`).join('');
        });

        document.getElementById('btnGuardarChecklist').addEventListener('click', async () => {
            if (!checklistPlantillaId) return;

            const detalles = Array.from(document.querySelectorAll('.checklist-item')).map(input => {
                const itemId = input.getAttribute('data-item-id');
                const comentario = document.querySelector(`.checklist-comentario[data-item-id="${itemId}"]`).value;
                return { checklistItemId: parseInt(itemId), cumple: input.checked, comentario };
            });

            const res = await (await apiFetch('/api/checklist/respuestas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ checklistPlantillaId, clienteId: parseInt(checklistClienteId), detalles })
            })).json();

            alert(res.message);
            if (res.success) document.getElementById('btnCerrarModalChecklist').click();
        });

        cargarPropietarios();
    </script>
}