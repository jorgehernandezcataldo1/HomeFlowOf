    // controladores MVC (hoy solo hay versiones API bajo /api/*), así que
    // estos links quedarán en 404 hasta que se creen esas vistas. Bootstrap
    // no valida esto en tiempo de compilación, así que no rompe el build.
}
<div class="sidebar-inner py-3">
    <ul class="nav nav-pills flex-column gap-1 px-2">
        <li class="nav-item">
            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Clientes" asp-action="Index">
                <i class="bi bi-people-fill me-2"></i>Clientes
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Propiedades" asp-action="Index">
                <i class="bi bi-building me-2"></i>Propiedades
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Visitas" asp-action="Index">
                <i class="bi bi-calendar-check me-2"></i>Visitas
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Checklists" asp-action="Index">
                <i class="bi bi-check2-square me-2"></i>Checklists
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Contratos" asp-action="Index">
